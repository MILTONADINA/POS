<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusions. Each entry suppresses a pattern that is a deliberate design choice in this
  codebase rather than a defect. Real findings are fixed in the source, not excluded here.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!-- The domain model intentionally shares mutable aggregate references: it is a single in-memory
       object graph with bidirectional relationships (Person<->Cashier, Item<->Price, Session<->...)
       mutated through the service layer. Defensive copies would sever those links, so exposing the
       internal representation is by design. -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
  </Match>

  <!-- Entity constructors validate their inputs and throw on invalid data by design. These classes
       declare no finalizers and are not used as an extension base, so the finalizer-attack concern
       this pattern guards against does not apply. -->
  <Match>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
  </Match>

  <!-- Entity constructors wire bidirectional relationships through add* helpers. The entities are
       simple data holders not designed for subclassing. -->
  <Match>
    <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR"/>
  </Match>

  <!-- Swing-specific noise in the GUI layer: event-listener anonymous classes intentionally capture
       enclosing-panel components, and Swing components are Serializable by inheritance even though
       this desktop application never serializes them. -->
  <Match>
    <Package name="~POSUI.*"/>
    <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON,SE_BAD_FIELD,SE_BAD_FIELD_STORE,SE_NO_SERIALVERSIONID,SE_INNER_CLASS"/>
  </Match>
</FindBugsFilter>
